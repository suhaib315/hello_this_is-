---
const currentYear = new Date().getFullYear();

const links = [
  { name: 'Privacy Policy', href: '/privacy' },
  { name: 'Terms of Service', href: '/terms' },
  { name: 'Contact Us', href: '/contact' },
];
---

<footer class="border-t border-hairline bg-canvas-soft">
  <div class="mx-auto max-w-[1400px] px-6 py-8">
    <nav class="flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-xs text-mute no-underline transition-colors hover:text-body"
        >
          {link.name}
        </a>
      ))}
    </nav>
    <p class="mt-4 text-center text-xs text-mute">&copy; {currentYear} Real Online Compass. All rights reserved.</p>
  </div>
</footer>
