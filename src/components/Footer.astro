---
const currentYear = new Date().getFullYear();

const tools = [
  { name: 'Compass', href: '/compass' },
  { name: 'Spirit Level', href: '/spirit-level' },
  { name: 'Inclinometer', href: '/inclinometer' },
  { name: 'Speedometer', href: '/speedometer' },
  { name: 'Light Meter', href: '/light-meter' },
  { name: 'EMF Meter', href: '/magnetometer' },
];

const resources = [
  { name: 'Privacy Policy', href: '/privacy' },
  { name: 'Terms of Service', href: '/terms' },
  { name: 'Contact', href: '/contact' },
];
---

<footer class="border-t border-hairline bg-canvas">
  <div class="mx-auto max-w-[1400px] px-6 py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-4">
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 text-ink no-underline">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" />
            <path d="M12 2v4M12 18v4M2 12h4M18 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            <circle cx="12" cy="12" r="2" fill="currentColor" />
          </svg>
          <span class="text-sm font-semibold">Real Online Compass</span>
        </a>
        <p class="mt-4 text-sm text-body leading-relaxed">
          Free online measurement tools. No app download required. Works on any device with a browser.
        </p>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-mono uppercase tracking-wider text-mute">Tools</h3>
        <ul class="flex flex-col gap-2">
          {tools.map((tool) => (
            <li>
              <a href={tool.href} class="text-sm text-body no-underline transition-colors hover:text-ink">
                {tool.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-mono uppercase tracking-wider text-mute">Resources</h3>
        <ul class="flex flex-col gap-2">
          {resources.map((resource) => (
            <li>
              <a href={resource.href} class="text-sm text-body no-underline transition-colors hover:text-ink">
                {resource.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-mono uppercase tracking-wider text-mute">Compatible With</h3>
        <ul class="flex flex-col gap-2">
          <li class="text-sm text-body">Chrome 63+</li>
          <li class="text-sm text-body">Safari 12+</li>
          <li class="text-sm text-body">Firefox 68+</li>
          <li class="text-sm text-body">Edge 79+</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-hairline pt-8 md:flex-row">
      <p class="text-xs text-mute">&copy; {currentYear} Real Online Compass. All rights reserved.</p>
      <p class="text-xs text-mute">Made with precision for professionals</p>
    </div>
  </div>
</footer>
