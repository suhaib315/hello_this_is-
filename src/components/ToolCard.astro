---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col gap-4 rounded-xl bg-canvas p-6 no-underline shadow-card transition-transform transition-shadow duration-200 hover:-translate-y-0.5 hover:shadow-elevated"
>
  <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-canvas-soft-2 text-xl transition-colors group-hover:bg-canvas-soft">
    {icon}
  </div>
  <div>
    <h3 class="text-base font-semibold text-ink tracking-tight">{title}</h3>
    <p class="mt-1 text-sm text-body leading-relaxed">{description}</p>
  </div>
  <div class="mt-auto flex items-center gap-1 text-sm font-medium text-link opacity-0 transition-opacity group-hover:opacity-100">
    Open tool
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
      <path d="M5.25 3.5l3.5 3.5-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
</a>
