---
const currentPath = Astro.url.pathname;

const tools = [
  { name: 'Compass', href: '/compass', icon: '🧭' },
  { name: 'Spirit Level', href: '/spirit-level', icon: '📐' },
  { name: 'Inclinometer', href: '/inclinometer', icon: '📏' },
  { name: 'Speedometer', href: '/speedometer', icon: '⚡' },
  { name: 'Light Meter', href: '/light-meter', icon: '💡' },
  { name: 'EMF Meter', href: '/magnetometer', icon: '🧲' },
];
---

<nav class="sticky top-0 z-50 h-16 bg-canvas/80 backdrop-blur-xl border-b border-hairline">
  <div class="mx-auto flex h-full max-w-[1400px] items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2 text-ink no-underline">
     <img src="/images/favicon-2/favicon.svg" alt="Compass Logo" class="w-6 h-6" />
      <span class="text-sm font-semibold tracking-tight">Real Online Compass</span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class:list={[
            'rounded-full px-3 py-1.5 text-sm text-body no-underline transition-colors hover:bg-canvas-soft-2 hover:text-ink',
            { 'bg-canvas-soft-2 text-ink font-medium': currentPath === tool.href },
          ]}
        >
          {tool.name}
        </a>
      ))}
    </div>

    <button id="mobile-menu-btn" class="flex h-8 w-8 items-center justify-center rounded-md border border-hairline text-body hover:bg-canvas-soft-2 md:hidden" aria-label="Toggle navigation menu">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-hairline bg-canvas md:hidden">
    <div class="flex flex-col gap-1 p-4">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class:list={[
            'rounded-lg px-4 py-2 text-sm text-body no-underline transition-colors hover:bg-canvas-soft-2 hover:text-ink',
            { 'bg-canvas-soft-2 text-ink font-medium': currentPath === tool.href },
          ]}
        >
          <span class="mr-2">{tool.icon}</span>
          {tool.name}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>