---
export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div id={id} class="flex items-center gap-2 text-sm font-medium text-body">
  <span class="relative flex h-2 w-2">
    <span class="relative inline-flex h-2 w-2 rounded-full bg-canvas-soft-2"></span>
  </span>
  <span>Initializing...</span>
</div>