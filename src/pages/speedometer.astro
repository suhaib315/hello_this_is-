---
import Layout from '../layouts/Layout.astro';
import SensorStatus from '../components/SensorStatus.astro';
---

<Layout title="Speedometer" description="Digital speedometer showing real-time speed">
  {/* Main background automatically switches between white (light mode) and zinc-950 (dark mode) */}
  <section class="min-h-screen bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 px-4 py-8">
    <div class="mx-auto max-w-[1400px]">

      {/* Header Area */}
      <div class="mb-10 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold tracking-tight">Speedometer</h1>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">Digital speedometer showing real-time speed</p>
        </div>
        <SensorStatus id="speed-sensor-status" />
      </div>

      {/* Main Speedometer Dial Container */}
      <div class="flex flex-col items-center justify-center gap-10 mt-10">
        
        {/* The Circular Dial */}
        <div class="relative flex h-[320px] w-[320px] items-center justify-center rounded-full bg-zinc-50 dark:bg-zinc-900 shadow-[0_8px_32px_rgba(0,0,0,0.05)] dark:shadow-[0_8px_32px_rgba(0,0,0,0.4)]">
          {/* Outer Ring */}
          <div class="absolute inset-0 rounded-full border-[10px] border-zinc-200 dark:border-zinc-800"></div>
          
          {/* Red Accent Arc to give it a "Speedometer" look without green */}
          <div class="absolute inset-0 rounded-full border-[10px] border-transparent border-t-red-600 border-r-red-600 opacity-90" style="transform: rotate(-45deg);"></div>

          {/* Speed Number Display */}
          <div class="text-center z-10 flex flex-col items-center">
            <span id="speedValue" class="text-8xl font-bold tracking-tighter text-zinc-900 dark:text-white">0</span>
            <span id="activeUnitLabel" class="mt-2 text-xl font-medium text-red-600">km/h</span>
          </div>
        </div>

        {/* Unit Toggle Buttons */}
        <div class="flex gap-4">
          <button id="unitKmh" class="w-24 py-3 rounded-full font-bold transition-all bg-red-600 text-white shadow-lg hover:bg-red-700">
            km/h
          </button>
          <button id="unitMph" class="w-24 py-3 rounded-full font-bold transition-all bg-zinc-200 dark:bg-zinc-800 text-zinc-900 dark:text-white hover:bg-zinc-300 dark:hover:bg-zinc-700">
            mph
          </button>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  // State variables
  let useKmh = true;
  let watchId = null;

  // DOM Elements
  const speedValue = document.getElementById('speedValue');
  const activeUnitLabel = document.getElementById('activeUnitLabel');
  const unitKmh = document.getElementById('unitKmh');
  const unitMph = document.getElementById('unitMph');
  const sensorStatus = document.getElementById('speed-sensor-status');

  // Active/Inactive Button Styling Classes
  const activeBtnClass = "w-24 py-3 rounded-full font-bold transition-all bg-red-600 text-white shadow-lg hover:bg-red-700";
  const inactiveBtnClass = "w-24 py-3 rounded-full font-bold transition-all bg-zinc-200 dark:bg-zinc-800 text-zinc-900 dark:text-white hover:bg-zinc-300 dark:hover:bg-zinc-700";

  // Function to handle the sensor status text colors (strictly red and neutral/white, no green)
  function setStatus(status:string, message:string) {
    if (sensorStatus) {
      sensorStatus.textContent = message;
      if (status === 'error') {
        sensorStatus.className = "text-red-600 font-medium";
      } else if (status === 'waiting') {
        sensorStatus.className = "text-zinc-500 dark:text-zinc-400";
      } else {
        sensorStatus.className = "text-zinc-900 dark:text-white font-medium"; 
      }
    }
  }

  // Geolocation Position Handler
  function handlePosition(position:GeolocationPosition) {
    setStatus('ready', 'Sensors ready');
    
    // The browser returns speed in meters per second (m/s)
    let speedMetersPerSecond = position.coords.speed;

    // If device is stationary or doesn't support speed calculation, it might return null
    if (speedMetersPerSecond === null) {
      speedMetersPerSecond = 0;
    }

    let displaySpeed = 0;
    if (useKmh) {
      displaySpeed = speedMetersPerSecond * 3.6; // Convert m/s to km/h
    } else {
      displaySpeed = speedMetersPerSecond * 2.23694; // Convert m/s to mph
    }

    if (speedValue) {
      speedValue.textContent = Math.round(displaySpeed).toString();
    }
  }

  // Geolocation Error Handler
  function handleError(error:GeolocationPositionError) {
    if (error.code === 1) setStatus('error', 'Location Denied');
    else setStatus('error', 'Signal Lost');
  }

  // Initialize Geolocation Tracking
  if ('geolocation' in navigator) {
    setStatus('waiting', 'Acquiring lock...');
    watchId = navigator.geolocation.watchPosition(handlePosition, handleError, {
      enableHighAccuracy: true,
      maximumAge: 0,
      timeout: 12000,
    });
  } else {
    setStatus('error', 'Unsupported');
  }

  // Unit Toggles with Button Style Swapping
  unitKmh?.addEventListener('click', () => {
    if (useKmh) return; // Do nothing if already in km/h
    useKmh = true;
    
    if (activeUnitLabel) activeUnitLabel.textContent = 'km/h';
    if (unitKmh) unitKmh.className = activeBtnClass;
    if (unitMph) unitMph.className = inactiveBtnClass;
  });

  unitMph?.addEventListener('click', () => {
    if (!useKmh) return; // Do nothing if already in mph
    useKmh = false;
    
    if (activeUnitLabel) activeUnitLabel.textContent = 'mph';
    if (unitMph) unitMph.className = activeBtnClass;
    if (unitKmh) unitKmh.className = inactiveBtnClass;
  });
</script>