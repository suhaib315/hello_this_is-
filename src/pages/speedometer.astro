---
import Layout from '../layouts/Layout.astro';
import SensorStatus from '../components/SensorStatus.astro';
---

<Layout title="Speedometer" description="Free online GPS speedometer. Track your speed in real-time without any app.">
  {/* Dark background container to match the app aesthetic */}
  <section class="min-h-screen bg-zinc-950 text-white font-sans">
    <div class="mx-auto max-w-[1400px] px-4 py-8 sm:py-16">
      
      {/* Header */}
      <div class="mb-10 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-white md:text-[32px]">
            Speedometer
          </h1>
          <p class="mt-1 text-sm text-zinc-400">Real-time GPS tracking</p>
        </div>
        <SensorStatus id="speed-sensor-status" />
      </div>

      <div class="flex flex-col items-center gap-10">
        
        {/* Main Speedometer Dial */}
        <div class="relative flex h-[320px] w-[320px] items-center justify-center sm:h-[400px] sm:w-[400px]">
          
          {/* SVG Glow Arc */}
          <svg class="absolute inset-0 h-full w-full -rotate-[135deg]" viewBox="0 0 300 300">
            {/* Background Track */}
            <circle cx="150" cy="150" r="130" fill="none" stroke="#27272a" stroke-width="20" stroke-dasharray="612.6 816.8" stroke-linecap="round"></circle>
            {/* Neon Active Track */}
            <circle id="speed-arc" cx="150" cy="150" r="130" fill="none" stroke="#34d399" stroke-width="20" stroke-dasharray="0 816.8" stroke-linecap="round" class="transition-all duration-300 ease-out" style="filter: drop-shadow(0 0 8px rgba(52,211,153,0.5));"></circle>
          </svg>

          {/* Numbers inside the dial */}
          <div class="absolute inset-0 flex items-center justify-center">
            {[0, 40, 80, 120, 160, 200, 240].map((speed) => {
              const angle = (speed / 240) * 270 - 135;
              return (
                <div class="absolute h-full w-px top-0 left-1/2 -translate-x-1/2 origin-center" style={{ transform: `rotate(${angle}deg)` }}>
                  <div class="absolute left-1/2 -translate-x-1/2 text-lg font-bold text-zinc-300" style={{ top: '45px', transform: `translateX(-50%) rotate(${-angle}deg)` }}>
                    {speed}
                  </div>
                </div>
              );
            })}
          </div>

          {/* Neon Needle */}
          <div id="speed-needle" class="absolute inset-0 z-10 transition-transform duration-300 ease-out" style="transform: rotate(-135deg)">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-[85%]">
              <div class="w-1.5 h-[100px] bg-emerald-400 rounded-t-full shadow-[0_0_10px_rgba(52,211,153,0.8)] sm:h-[130px]"></div>
            </div>
          </div>

          {/* Center Hub */}
          <div class="absolute h-10 w-10 rounded-full bg-zinc-900 border-4 border-emerald-400 z-20 shadow-[0_0_15px_rgba(52,211,153,0.5)] flex items-center justify-center">
            <div class="h-3 w-3 bg-emerald-400 rounded-full"></div>
          </div>

          {/* Core Digital Speed Readout */}
          <div class="absolute bottom-[10%] text-center z-20 flex flex-col items-center">
            <div class="font-bold tracking-tighter text-white tabular-nums leading-none text-[80px]">
              <span id="speed-value">0</span>
            </div>
            <div id="active-unit-label" class="text-lg font-semibold text-zinc-400 mt-1">km/h</div>
          </div>
        </div>

        {/* Toggle Controls */}
        <div class="flex items-center justify-center gap-2 bg-zinc-900 p-1.5 rounded-full border border-zinc-800">
          <button id="speed-unit-kmh" class="rounded-full bg-emerald-500 px-6 py-2 text-sm font-bold text-zinc-950 shadow transition-all duration-200">
            km/h
          </button>
          <button id="speed-unit-mph" class="rounded-full px-6 py-2 text-sm font-bold text-zinc-400 transition-all duration-200 hover:text-white">
            MPH
          </button>
        </div>

        {/* Trip Stats Cards */}
        <div class="grid grid-cols-3 gap-3 w-full max-w-lg">
          {/* Distance */}
          <div class="rounded-2xl bg-zinc-900/80 border border-zinc-800 p-4 flex flex-col items-center justify-center">
            <div class="font-bold text-3xl text-emerald-400 tabular-nums leading-none mb-1"><span id="stat-distance">0.0</span></div>
            <div class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Distance</div>
            <div id="unit-dist" class="text-[10px] text-zinc-600">km</div>
          </div>
          
          {/* Avg Speed */}
          <div class="rounded-2xl bg-zinc-900/80 border border-zinc-800 p-4 flex flex-col items-center justify-center">
            <div class="font-bold text-3xl text-emerald-400 tabular-nums leading-none mb-1"><span id="stat-avg">0</span></div>
            <div class="text-xs font-medium text-zinc-500 uppercase tracking-wider text-center">Avg. Speed</div>
          </div>

          {/* Max Speed */}
          <div class="rounded-2xl bg-zinc-900/80 border border-zinc-800 p-4 flex flex-col items-center justify-center">
            <div class="font-bold text-3xl text-emerald-400 tabular-nums leading-none mb-1"><span id="stat-max">0</span></div>
            <div class="text-xs font-medium text-zinc-500 uppercase tracking-wider text-center">Max. Speed</div>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  const needle = document.getElementById('speed-needle');
  const arc = document.getElementById('speed-arc');
  const valueEl = document.getElementById('speed-value');
  
  const statDistEl = document.getElementById('stat-distance');
  const statAvgEl = document.getElementById('stat-avg');
  const statMaxEl = document.getElementById('stat-max');
  const unitDistEl = document.getElementById('unit-dist');
  
  const unitKmh = document.getElementById('speed-unit-kmh');
  const unitMph = document.getElementById('speed-unit-mph');
  const activeUnitLabel = document.getElementById('active-unit-label');
  const statusEl = document.getElementById('speed-sensor-status');

  let useKmh = true;
  
  // Tracking Variables
  let lastPosition: GeolocationCoordinates | null = null;
  let lastTime = 0;
  let tripStartTime = 0;
  let totalDistanceKm = 0;
  let maxSpeedKmh = 0;

  const ARC_MAX = 612.6;

  function setStatus(state: 'ready' | 'waiting' | 'error', message: string) {
    if (!statusEl) return;
    const colors = { ready: 'bg-emerald-500', waiting: 'bg-amber-500', error: 'bg-red-500' };
    statusEl.innerHTML = `
      <span class="relative flex h-2 w-2">
        ${state === 'waiting' ? `<span class="absolute inline-flex h-full w-full animate-ping rounded-full ${colors[state]} opacity-75"></span>` : ''}
        <span class="relative inline-flex h-2 w-2 rounded-full ${colors[state]}"></span>
      </span>
      <span class="text-zinc-400 text-xs ml-2">${message}</span>
    `;
  }

  function updateUI(speedKmh: number) {
    const safeKmh = Math.max(0, speedKmh);
    
    // Update Max Speed
    if (safeKmh > maxSpeedKmh) maxSpeedKmh = safeKmh;

    // Calculate Avg Speed (Distance / Time)
    let avgSpeedKmh = 0;
    if (tripStartTime > 0 && totalDistanceKm > 0) {
      const hoursElapsed = (Date.now() - tripStartTime) / (1000 * 60 * 60);
      avgSpeedKmh = totalDistanceKm / hoursElapsed;
    }

    // Apply Unit Conversions
    const multiplier = useKmh ? 1 : 0.621371;
    const displaySpeed = safeKmh * multiplier;
    const displayMax = maxSpeedKmh * multiplier;
    const displayAvg = avgSpeedKmh * multiplier;
    const displayDist = totalDistanceKm * multiplier;

    // Update Text Elements
    if (valueEl) valueEl.textContent = Math.round(displaySpeed).toString();
    if (statMaxEl) statMaxEl.textContent = Math.round(displayMax).toString();
    if (statAvgEl) statAvgEl.textContent = Math.round(displayAvg).toString();
    if (statDistEl) statDistEl.textContent = displayDist.toFixed(1);

    // Update Dial (Max scale 240)
    const dialRatio = Math.min(displaySpeed, 240) / 240;
    const angle = -135 + (dialRatio * 270);
    const dashOffset = dialRatio * ARC_MAX;
    
    if (needle) needle.style.transform = `rotate(${angle}deg)`;
    if (arc) arc.style.strokeDasharray = `${dashOffset} 816.8`;
  }

  function handlePosition(position: GeolocationPosition) {
    if (tripStartTime === 0) tripStartTime = Date.now();
    setStatus('ready', 'GPS Active');
    
    const coords = position.coords;
    const currentTime = Date.now();

    let computedSpeedKmh = 0;

    // Calculate distance and fallback speed
    if (lastPosition && lastTime) {
      const timeDelta = (currentTime - lastTime) / 1000;
      if (timeDelta > 0) {
        const lat1 = lastPosition.latitude;
        const lng1 = lastPosition.longitude;
        const lat2 = coords.latitude;
        const lng2 = coords.longitude;

        const R = 6371; // km
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLng = (lng2 - lng1) * Math.PI / 180;
        const a = Math.sin(dLat / 2) ** 2 + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLng / 2) ** 2;
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        const distanceKm = R * c; 

        // Filter out GPS drift (only count movement > 1.5 meters)
        if (distanceKm > 0.0015) {
          totalDistanceKm += distanceKm;
          computedSpeedKmh = (distanceKm * 1000 / timeDelta) * 3.6;
        }
      }
    }

    // Prefer hardware speed if available
    if (coords.speed !== null && coords.speed >= 0) {
      // If hardware speed is tiny (drift), zero it out
      computedSpeedKmh = coords.speed < 0.5 ? 0 : coords.speed * 3.6; 
    }

    updateUI(computedSpeedKmh);

    lastPosition = coords;
    lastTime = currentTime;
  }

  function handleError(error: GeolocationPositionError) {
    if (error.code === 1) setStatus('error', 'Location Denied');
    else setStatus('error', 'Signal Lost');
  }

  if ('geolocation' in navigator) {
    setStatus('waiting', 'Acquiring lock…');
    navigator.geolocation.watchPosition(handlePosition, handleError, {
      enableHighAccuracy: true,
      maximumAge: 0,
      timeout: 12000,
    });
  } else {
    setStatus('error', 'Unsupported');
  }

  // Unit Toggles
  unitKmh?.addEventListener('click', () => {
    if (useKmh) return;
    useKmh = true;
    if (activeUnitLabel) activeUnitLabel.textContent = 'km/h';
  });