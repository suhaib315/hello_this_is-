---
import Layout from '../layouts/Layout.astro';
import SensorStatus from '../components/SensorStatus.astro';
---

<Layout title="Spirit Level" description="Free online bubble level. Check if a surface is horizontal or vertical with precision.">
  <section class="bg-canvas-soft">
    <div class="mx-auto max-w-[1400px] px-6 py-16">
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold tracking-tight text-ink md:text-[32px] md:leading-[40px] md:tracking-[-1.28px]">
            Spirit Level
          </h1>
          <p class="mt-2 text-sm text-body">Bubble level for horizontal and vertical surfaces</p>
        </div>
        <SensorStatus id="level-sensor-status" />
      </div>

      <div class="flex flex-col items-center gap-8">
        {/* Level Display */}
        <div class="relative flex h-[320px] w-[320px] items-center justify-center rounded-full bg-canvas shadow-elevated sm:h-[400px] sm:w-[400px]">
          {/* Grid Lines */}
          <div class="absolute inset-12 grid grid-cols-5 grid-rows-5">
            {Array.from({ length: 25 }, (_, i) => (
              <div class="border border-hairline/50"></div>
            ))}
          </div>

          {/* Crosshair */}
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="h-px w-full bg-hairline-strong/30"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="h-full w-px bg-hairline-strong/30"></div>
          </div>

          {/* Center Target */}
          <div class="absolute h-4 w-4 rounded-full border-2 border-link"></div>
          <div class="absolute h-1 w-1 rounded-full bg-link"></div>

          {/* Bubble */}
          <div
            id="level-bubble"
            class="absolute h-8 w-8 rounded-full bg-link/20 border-2 border-link transition-transform duration-200 ease-out"
            style="transform: translate(0px, 0px)"
          ></div>
        </div>

        {/* Readings */}
        <div class="flex gap-8">
          <div class="text-center">
            <div class="font-mono text-3xl font-semibold tracking-tight text-ink tabular-nums">
              <span id="level-x">0.0</span><span class="text-lg text-mute">°</span>
            </div>
            <div class="mt-1 text-xs font-medium text-body">Pitch (X)</div>
          </div>
          <div class="text-center">
            <div class="font-mono text-3xl font-semibold tracking-tight text-ink tabular-nums">
              <span id="level-y">0.0</span><span class="text-lg text-mute">°</span>
            </div>
            <div class="mt-1 text-xs font-medium text-body">Roll (Y)</div>
          </div>
        </div>

        {/* Level Status */}
        <div id="level-status" class="rounded-full bg-canvas-soft-2 px-4 py-2 text-sm font-medium text-body">
          Place device on a surface
        </div>

        {/* Instructions */}
        <div class="w-full max-w-md rounded-xl bg-canvas p-6 shadow-card">
          <h3 class="mb-3 text-sm font-semibold text-ink">How to use</h3>
          <ul class="flex flex-col gap-2 text-sm text-body">
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-mute">1.</span>
              Place your device flat on the surface
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-mute">2.</span>
              The bubble moves toward center when level
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-mute">3.</span>
              Both readings near 0° means perfectly level
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const bubble = document.getElementById('level-bubble');
  const xEl = document.getElementById('level-x');
  const yEl = document.getElementById('level-y');
  const statusEl = document.getElementById('level-status');

  function handleOrientation(event: DeviceOrientationEvent) {
    const beta = event.beta ?? 0;   // X-axis: front-back tilt (-180 to 180)
    const gamma = event.gamma ?? 0; // Y-axis: left-right tilt (-90 to 90)

    const maxOffset = 120;
    const maxAngle = 45;

    const xOffset = Math.max(-maxOffset, Math.min(maxOffset, (gamma / maxAngle) * maxOffset));
    const yOffset = Math.max(-maxOffset, Math.min(maxOffset, ((beta - 45) / maxAngle) * maxOffset));

    if (bubble) {
      bubble.style.transform = `translate(${xOffset}px, ${yOffset}px)`;
    }
    if (xEl) {
      xEl.textContent = gamma.toFixed(1);
    }
    if (yEl) {
      yEl.textContent = (beta - 45).toFixed(1);
    }

    const isLevel = Math.abs(gamma) < 1 && Math.abs(beta - 45) < 1;
    if (statusEl) {
      statusEl.textContent = isLevel ? 'Level' : 'Not level';
      statusEl.className = isLevel
        ? 'rounded-full bg-success/10 px-4 py-2 text-sm font-medium text-success'
        : 'rounded-full bg-canvas-soft-2 px-4 py-2 text-sm font-medium text-body';
    }
  }

  async function requestPermission() {
    if (typeof (DeviceOrientationEvent as any).requestPermission === 'function') {
      try {
        const permission = await (DeviceOrientationEvent as any).requestPermission();
        if (permission === 'granted') {
          window.addEventListener('deviceorientation', handleOrientation, true);
        }
      } catch (e) {
        console.error('Orientation permission denied', e);
      }
    } else {
      window.addEventListener('deviceorientation', handleOrientation, true);
    }
  }

  requestPermission();
</script>
