---
import Layout from '../layouts/Layout.astro';
import SensorStatus from '../components/SensorStatus.astro';
---

<Layout title="Compass" description="Free online digital compass showing real-time direction. Works on any device with a magnetometer.">
  <section class="bg-canvas-soft">
    <div class="mx-auto max-w-[1400px] px-6 py-16">
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold tracking-tight text-ink md:text-[32px] md:leading-[40px] md:tracking-[-1.28px]">
            Compass
          </h1>
          <p class="mt-2 text-sm text-body">Digital compass showing real-time direction</p>
        </div>
        <div class="flex items-center gap-3">
          <button
            id="fullscreen-btn"
            class="flex h-8 w-8 items-center justify-center rounded-full border border-hairline bg-canvas text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
            aria-label="Toggle fullscreen compass"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 5V1h4M9 1h4v4M13 9v4H9M5 13H1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <SensorStatus id="compass-sensor-status" />
        </div>
      </div>

      <div class="flex flex-col items-center gap-6">
        {/* Compass Display */}
        <div id="compass-container" class="relative flex h-[300px] w-[300px] items-center justify-center sm:h-[380px] sm:w-[380px]">
          {/* Outer Metallic Ring */}
          <div class="compass-outer-ring absolute inset-0 rounded-full"></div>

          {/* North Marker (red triangle at top of ring) */}
          <div class="compass-north-marker absolute -top-0 left-1/2 h-0 w-0 -translate-x-1/2" style="border-left: 7px solid transparent; border-right: 7px solid transparent; border-top: 14px solid #cc0000;"></div>

          {/* Inner Compass Face */}
          <div id="compass-face" class="compass-inner-face absolute inset-[12px] rounded-full sm:inset-[14px]">
            {/* Degree Markers */}
            {Array.from({ length: 72 }, (_, i) => i * 5).map((deg) => (
              <div class="absolute h-full w-px origin-center" style={{ transform: `rotate(${deg}deg)` }}>
                <div class:list={[
                  'mx-auto',
                  deg % 90 === 0 ? 'h-4 w-[2px]' : deg % 30 === 0 ? 'h-3 w-[1.5px]' : deg % 15 === 0 ? 'h-2.5 w-px' : 'h-2 w-px',
                ]} style={{
                  background: deg % 90 === 0
                    ? (deg === 0 ? '#cc0000' : 'var(--color-ink)')
                    : deg % 30 === 0
                    ? 'var(--color-body)'
                    : deg % 15 === 0
                    ? 'var(--color-mute)'
                    : 'var(--color-hairline-strong)',
                }}></div>
              </div>
            ))}

            {/* Cardinal Labels */}
            <span class="compass-cardinal-label absolute top-6 left-1/2 -translate-x-1/2 text-[14px] font-mono text-error sm:text-[16px]">N</span>
            <span class="compass-cardinal-label absolute bottom-6 left-1/2 -translate-x-1/2 text-[14px] font-mono text-ink sm:text-[16px]">S</span>
            <span class="compass-cardinal-label absolute top-1/2 left-6 -translate-y-1/2 text-[14px] font-mono text-ink sm:text-[16px]">W</span>
            <span class="compass-cardinal-label absolute top-1/2 right-6 -translate-y-1/2 text-[14px] font-mono text-ink sm:text-[16px]">E</span>

            {/* Intercardinal Labels */}
            {[
              { label: 'NE', angle: 45 },
              { label: 'SE', angle: 135 },
              { label: 'SW', angle: 225 },
              { label: 'NW', angle: 315 },
            ].map(({ label, angle }) => {
              const rad = (angle - 90) * (Math.PI / 180);
              const r = 110;
              return (
                <span
                  class="compass-intercardinal-label absolute text-[10px] font-mono text-body sm:text-[11px]"
                  style={{
                    left: `calc(50% + ${r * Math.cos(rad)}px)`,
                    top: `calc(50% + ${r * Math.sin(rad)}px)`,
                    transform: 'translate(-50%, -50%)',
                  }}
                >
                  {label}
                </span>
              );
            })}
          </div>

          {/* Compass Needle */}
          <div id="compass-needle" class="absolute h-full w-full" style="transform: rotate(0deg);">
            {/* North (Red) - Tapered diamond shape */}
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-full">
              <div class="compass-needle-north" style="width: 0; height: 0; border-left: 6px solid transparent; border-right: 6px solid transparent; border-bottom: 105px solid #cc0000;"></div>
            </div>
            {/* South (Dark) - Tapered diamond shape */}
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2">
              <div class="compass-needle-south" style="width: 0; height: 0; border-left: 6px solid transparent; border-right: 6px solid transparent; border-top: 105px solid #2d2d44;"></div>
            </div>
          </div>

          {/* Center Hub */}
          <div class="compass-center-hub absolute h-5 w-5 rounded-full sm:h-6 sm:w-6"></div>

          {/* North Glow Feedback */}
          <div id="north-glow" class="pointer-events-none absolute inset-0 rounded-full opacity-0 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 8%, rgba(238,0,0,0.15) 0%, transparent 25%);"></div>
        </div>

        {/* Degree Display */}
        <div class="text-center">
          <div class="flex items-baseline justify-center gap-1">
            <span id="compass-degrees" class="font-mono text-5xl font-semibold tracking-tight text-ink tabular-nums">0</span>
            <span class="text-2xl text-mute">°</span>
          </div>
          <div id="compass-direction" class="mt-1.5 text-sm font-medium text-body">North</div>
        </div>

        {/* Status / Error */}
        <div id="compass-message" class="hidden max-w-md rounded-xl border border-error-soft bg-error-soft/30 px-4 py-3 text-sm text-error"></div>

        {/* Instructions */}
        <div class="w-full max-w-md rounded-xl bg-canvas p-6 shadow-card">
          <h3 class="mb-3 text-sm font-semibold text-ink">How to use</h3>
          <ul class="flex flex-col gap-2 text-sm text-body">
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-mute">1.</span>
              Grant sensor access when prompted
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-mute">2.</span>
              Hold your device flat, screen facing up
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-mute">3.</span>
              The red end of the needle points North
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* Fullscreen Compass Overlay */}
  <div id="compass-fullscreen" class="compass-fullscreen">
    <div class="mb-4 flex w-full max-w-md items-center justify-between">
      <div>
        <div class="text-sm font-semibold text-ink">Compass</div>
        <div class="text-xs text-body" id="fs-direction-full">North</div>
      </div>
      <button
        id="fullscreen-close"
        class="flex h-8 w-8 items-center justify-center rounded-full border border-hairline bg-canvas text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        aria-label="Exit fullscreen"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <div class="relative flex h-[min(80vw,380px)] w-[min(80vw,380px)] items-center justify-center">
      {/* Outer Metallic Ring */}
      <div class="compass-outer-ring absolute inset-0 rounded-full"></div>

      {/* North Marker */}
      <div class="compass-north-marker absolute -top-0 left-1/2 h-0 w-0 -translate-x-1/2" style="border-left: 7px solid transparent; border-right: 7px solid transparent; border-top: 14px solid #cc0000;"></div>

      {/* Inner Compass Face */}
      <div class="compass-inner-face absolute inset-[12px] rounded-full">
        {/* Degree Markers */}
        {Array.from({ length: 72 }, (_, i) => i * 5).map((deg) => (
          <div class="absolute h-full w-px origin-center" style={{ transform: `rotate(${deg}deg)` }}>
            <div class:list={[
              'mx-auto',
              deg % 90 === 0 ? 'h-4 w-[2px]' : deg % 30 === 0 ? 'h-3 w-[1.5px]' : 'h-2.5 w-px',
            ]} style={{
              background: deg % 90 === 0
                ? (deg === 0 ? '#cc0000' : 'var(--color-ink)')
                : deg % 30 === 0
                ? 'var(--color-body)'
                : 'var(--color-mute)',
            }}></div>
          </div>
        ))}

        {/* Cardinal Labels */}
        <span class="compass-cardinal-label absolute top-6 left-1/2 -translate-x-1/2 text-[14px] font-mono text-error">N</span>
        <span class="compass-cardinal-label absolute bottom-6 left-1/2 -translate-x-1/2 text-[14px] font-mono text-ink">S</span>
        <span class="compass-cardinal-label absolute top-1/2 left-6 -translate-y-1/2 text-[14px] font-mono text-ink">W</span>
        <span class="compass-cardinal-label absolute top-1/2 right-6 -translate-y-1/2 text-[14px] font-mono text-ink">E</span>

        {/* Intercardinal Labels */}
        {[
          { label: 'NE', angle: 45 },
          { label: 'SE', angle: 135 },
          { label: 'SW', angle: 225 },
          { label: 'NW', angle: 315 },
        ].map(({ label, angle }) => {
          const rad = (angle - 90) * (Math.PI / 180);
          const r = 110;
          return (
            <span
              class="compass-intercardinal-label absolute text-[10px] font-mono text-body"
              style={{
                left: `calc(50% + ${r * Math.cos(rad)}px)`,
                top: `calc(50% + ${r * Math.sin(rad)}px)`,
                transform: 'translate(-50%, -50%)',
              }}
            >
              {label}
            </span>
          );
        })}
      </div>

      {/* Compass Needle */}
      <div id="fs-needle" class="absolute h-full w-full" style="transform: rotate(0deg);">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-full">
          <div class="compass-needle-north" style="width: 0; height: 0; border-left: 6px solid transparent; border-right: 6px solid transparent; border-bottom: 105px solid #cc0000;"></div>
        </div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2">
          <div class="compass-needle-south" style="width: 0; height: 0; border-left: 6px solid transparent; border-right: 6px solid transparent; border-top: 105px solid #2d2d44;"></div>
        </div>
      </div>

      {/* Center Hub */}
      <div class="compass-center-hub absolute h-5 w-5 rounded-full"></div>

      {/* North Glow Feedback */}
      <div id="fs-north-glow" class="pointer-events-none absolute inset-0 rounded-full opacity-0 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 8%, rgba(238,0,0,0.15) 0%, transparent 25%);"></div>
    </div>

    <div class="mt-6 text-center">
      <div class="flex items-baseline justify-center gap-1">
        <span id="fs-degrees" class="font-mono text-5xl font-semibold tracking-tight text-ink tabular-nums">0</span>
        <span class="text-2xl text-mute">°</span>
      </div>
    </div>
  </div>

  {/* Permission Modal */}
  <div
    id="permission-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/40 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <div class="mx-4 w-full max-w-sm rounded-2xl bg-canvas p-6 shadow-float">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-canvas-soft-2">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="1.5" class="text-ink" />
          <path d="M14 5v3M14 20v3M5 14h3M20 14h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-mute" />
          <path d="M14 7l2 7-2-2-2 2 2-7z" fill="#ee0000" />
          <path d="M14 21l-2-7 2 2 2-2-2 7z" fill="#a1a1a1" />
        </svg>
      </div>
      <h2 id="modal-title" class="text-center text-base font-semibold text-ink">Enable Compass</h2>
      <p class="mt-2 text-center text-sm text-body leading-relaxed">
        This compass needs access to your device sensors to determine direction.
      </p>
      <div id="modal-loading" class="hidden mt-5 flex items-center justify-center gap-2 py-3">
        <svg class="h-4 w-4 animate-spin text-body" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-25" />
          <path d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z" fill="currentColor" class="opacity-75" />
        </svg>
        <span class="text-sm text-body">Requesting access…</span>
      </div>
      <div id="modal-buttons" class="mt-5 flex gap-3">
        <button id="modal-cancel" class="flex-1 h-10 rounded-full bg-canvas-soft-2 px-4 text-sm font-medium text-body transition-colors hover:bg-canvas-soft">
          Cancel
        </button>
        <button id="modal-enable" class="flex-1 h-10 rounded-full bg-primary px-4 text-sm font-medium text-on-primary transition-colors hover:bg-ink/80">
          Enable Compass
        </button>
      </div>
      <div id="modal-denied" class="hidden mt-4 rounded-lg bg-error-soft/30 p-3">
        <p class="text-xs text-error leading-relaxed" id="modal-denied-text"></p>
      </div>
    </div>
  </div>
</Layout>

<script>
  // DOM elements
  const needleEl = document.getElementById('compass-needle');
  const degreesEl = document.getElementById('compass-degrees');
  const directionEl = document.getElementById('compass-direction');
  const messageEl = document.getElementById('compass-message');
  const statusEl = document.getElementById('compass-sensor-status');
  const northGlow = document.getElementById('north-glow');
  const fullscreenBtn = document.getElementById('fullscreen-btn');
  const fullscreenOverlay = document.getElementById('compass-fullscreen');
  const fullscreenClose = document.getElementById('fullscreen-close');
  const fsNeedle = document.getElementById('fs-needle');
  const fsDegrees = document.getElementById('fs-degrees');
  const fsDirection = document.getElementById('fs-direction-full');
  const fsNorthGlow = document.getElementById('fs-north-glow');

  const modal = document.getElementById('permission-modal')!;
  const modalEnable = document.getElementById('modal-enable')!;
  const modalCancel = document.getElementById('modal-cancel')!;
  const modalLoading = document.getElementById('modal-loading')!;
  const modalButtons = document.getElementById('modal-buttons')!;
  const modalDenied = document.getElementById('modal-denied')!;
  const modalDeniedText = document.getElementById('modal-denied-text')!;

  // State
  let isRunning = false;
  let isFullscreen = false;
  let rawHeading = 0;       // Latest sensor reading — used for all display text
  let displayHeading = 0;   // Smoothed value — used only for needle rotation
  let lastFrameTime = 0;

  // Animation config — visual only, zero impact on accuracy
  const LERP_SPEED = 0.18;        // Needle interpolation per frame (~0.18 = smooth but responsive)
  const DEAD_ZONE = 0.3;          // Minimal dead zone — preserve all real movement
  const NORTH_THRESHOLD = 2;

  // --- Helpers ---

  function showMessage(msg: string) {
    if (messageEl) {
      messageEl.textContent = msg;
      messageEl.classList.remove('hidden');
    }
  }

  function hideMessage() {
    messageEl?.classList.add('hidden');
  }

  function setStatus(state: 'ready' | 'waiting' | 'error', message: string) {
    if (!statusEl) return;
    const colors = { ready: 'bg-success', waiting: 'bg-warning', error: 'bg-error' };
    statusEl.innerHTML = `
      <span class="relative flex h-2 w-2">
        ${state === 'waiting' ? `<span class="absolute inline-flex h-full w-full animate-ping rounded-full ${colors[state]} opacity-75"></span>` : ''}
        <span class="relative inline-flex h-2 w-2 rounded-full ${colors[state]}"></span>
      </span>
      <span class="text-body">${message}</span>
    `;
  }

  function showModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    modalLoading.classList.add('hidden');
    modalButtons.classList.remove('hidden');
    modalDenied.classList.add('hidden');
    document.body.style.overflow = 'hidden';
  }

  function hideModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function showModalLoading() {
    modalLoading.classList.remove('hidden');
    modalButtons.classList.add('hidden');
    modalDenied.classList.add('hidden');
  }

  function showModalDenied(msg: string) {
    modalLoading.classList.add('hidden');
    modalButtons.classList.add('hidden');
    modalDenied.classList.remove('hidden');
    modalDeniedText.textContent = msg;
  }

  function getCardinal(deg: number): string {
    const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];
    return dirs[Math.round(deg / 45) % 8];
  }

  function getDirectionName(deg: number): string {
    const names = ['North', 'North-East', 'East', 'South-East', 'South', 'South-West', 'West', 'North-West'];
    return names[Math.round(deg / 45) % 8];
  }

  // --- Smooth Needle Logic ---

  function shortestRotation(from: number, to: number): number {
    let diff = to - from;
    if (diff > 180) diff -= 360;
    if (diff < -180) diff += 360;
    return diff;
  }

  function animate(now: number) {
    // Interpolate needle rotation toward raw heading (visual only)
    const diff = shortestRotation(displayHeading, rawHeading);

    if (Math.abs(diff) > DEAD_ZONE) {
      displayHeading += diff * LERP_SPEED;
      displayHeading = ((displayHeading % 360) + 360) % 360;
    } else {
      displayHeading = rawHeading;
    }

    updateDisplay(rawHeading, displayHeading);
    requestAnimationFrame(animate);
  }

  // --- North Alignment Feedback ---

  function updateNorthFeedback(heading: number) {
    const distFromNorth = Math.min(heading, 360 - heading);
    const isNearNorth = distFromNorth <= NORTH_THRESHOLD;

    if (northGlow) northGlow.style.opacity = isNearNorth ? '1' : '0';
    if (fsNorthGlow) fsNorthGlow.style.opacity = isNearNorth ? '1' : '0';
  }

  // --- Update Display ---

  function updateDisplay(raw: number, needle: number) {
    const rounded = Math.round(raw);
    const cardinal = getCardinal(raw);
    const dirName = getDirectionName(raw);

    if (needleEl) needleEl.style.transform = `rotate(${-needle}deg)`;
    if (degreesEl) degreesEl.textContent = rounded.toString();
    if (directionEl) directionEl.textContent = `${dirName} (${cardinal})`;

    if (fsNeedle) fsNeedle.style.transform = `rotate(${-needle}deg)`;
    if (fsDegrees) fsDegrees.textContent = rounded.toString();
    if (fsDirection) fsDirection.textContent = dirName;

    updateNorthFeedback(raw);
  }

  // --- Orientation Handler ---

  function handleOrientation(event: DeviceOrientationEvent) {
    let raw: number | null = null;

    if ('webkitCompassHeading' in event) {
      raw = (event as any).webkitCompassHeading;
    } else if (event.alpha !== null) {
      raw = event.absolute ? 360 - event.alpha : 360 - event.alpha;
    }

    if (raw === null || isNaN(raw)) return;

    raw = ((raw % 360) + 360) % 360;

    if (!isRunning) {
      isRunning = true;
      rawHeading = raw;
      displayHeading = raw;
      hideMessage();
      hideModal();
      setStatus('ready', 'Sensors ready');
      requestAnimationFrame(animate);
    }

    rawHeading = raw;
  }

  // --- Fullscreen ---

  function enterFullscreen() {
    fullscreenOverlay?.classList.add('active');
    isFullscreen = true;
    document.body.style.overflow = 'hidden';

    const el = fullscreenOverlay as any;
    if (el.requestFullscreen) {
      el.requestFullscreen().catch(() => {});
    } else if (el.webkitRequestFullscreen) {
      el.webkitRequestFullscreen();
    }
  }

  function exitFullscreen() {
    fullscreenOverlay?.classList.remove('active');
    isFullscreen = false;
    document.body.style.overflow = '';

    if (document.exitFullscreen) {
      document.exitFullscreen().catch(() => {});
    } else if (document.webkitExitFullscreen) {
      document.webkitExitFullscreen();
    }
  }

  fullscreenBtn?.addEventListener('click', enterFullscreen);
  fullscreenClose?.addEventListener('click', exitFullscreen);

  document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement && isFullscreen) {
      exitFullscreen();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (isFullscreen) exitFullscreen();
      else if (!modal.classList.contains('hidden')) {
        hideModal();
        setStatus('waiting', 'Permission needed');
      }
    }
  });

  // --- Permission ---

  async function requestPermission() {
    showModalLoading();

    if (typeof (DeviceOrientationEvent as any).requestPermission === 'function') {
      try {
        const permission = await (DeviceOrientationEvent as any).requestPermission();
        if (permission === 'granted') {
          window.addEventListener('deviceorientation', handleOrientation, true);
          hideModal();
          setStatus('ready', 'Sensors ready');
        } else {
          showModalDenied(
            'Compass access was denied. To enable it:\n' +
            '1. Open Settings → Safari\n' +
            '2. Tap "Motion & Orientation Access"\n' +
            '3. Enable it, then reload this page'
          );
          setStatus('error', 'Permission denied');
        }
      } catch (err: any) {
        showModalDenied('Could not request compass access. Try reloading the page.');
        setStatus('error', 'Permission error');
      }
    } else if ('DeviceOrientationEvent' in window) {
      window.addEventListener('deviceorientation', handleOrientation, true);
      hideModal();
      setStatus('ready', 'Listening…');

      setTimeout(() => {
        if (!isRunning) {
          setStatus('error', 'No data');
          showMessage('Your device does not support compass sensors.');
        }
      }, 2000);
    } else {
      showModalDenied('Your browser does not support device orientation sensors.');
      setStatus('error', 'Not supported');
    }
  }

  // --- Init ---

  function init() {
    if (!window.isSecureContext) {
      setStatus('error', 'Insecure connection');
      showMessage('Compass access requires a secure HTTPS connection.');
      return;
    }

    if (!('DeviceOrientationEvent' in window)) {
      setStatus('error', 'Not supported');
      showMessage('Your device does not support compass sensors.');
      return;
    }

    if (typeof (DeviceOrientationEvent as any).requestPermission === 'function') {
      setStatus('waiting', 'Permission needed');
      showModal();
      return;
    }

    let gotData = false;
    const testHandler = (e: DeviceOrientationEvent) => {
      if (e.alpha !== null || ('webkitCompassHeading' in e)) {
        gotData = true;
        window.removeEventListener('deviceorientation', testHandler, true);
        window.addEventListener('deviceorientation', handleOrientation, true);
        setStatus('ready', 'Sensors ready');
      }
    };
    window.addEventListener('deviceorientation', testHandler, true);

    setTimeout(() => {
      if (!gotData && !isRunning) {
        setStatus('error', 'No sensors');
        showMessage('Your device does not support compass sensors.');
      }
    }, 2000);
  }

  modalEnable.addEventListener('click', requestPermission);
  modalCancel.addEventListener('click', () => {
    hideModal();
    setStatus('waiting', 'Permission needed');
  });
  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      hideModal();
      setStatus('waiting', 'Permission needed');
    }
  });

  init();
</script>
