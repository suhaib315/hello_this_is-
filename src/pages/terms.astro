---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Service" description="Terms of service for Real Online Compass.">
  <section class="bg-canvas-soft">
    <div class="mx-auto max-w-3xl px-6 py-24">
      <h1 class="text-2xl font-semibold tracking-tight text-ink md:text-[32px] md:leading-[40px] md:tracking-[-1.28px]">
        Terms of Service
      </h1>
      <p class="mt-4 text-sm text-mute">Last updated: June 2026</p>

      <div class="mt-8 flex flex-col gap-8 text-body">
        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Usage</h2>
          <p class="text-sm leading-relaxed">
            Real Online Compass provides measurement tools for informational purposes only. We do not guarantee the accuracy of readings and recommend using professional instruments for critical measurements.
          </p>
        </div>

        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Limitation of Liability</h2>
          <p class="text-sm leading-relaxed">
            Real Online Compass is provided "as is" without warranties of any kind. We are not liable for any damages arising from the use of this service.
          </p>
        </div>

        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Intellectual Property</h2>
          <p class="text-sm leading-relaxed">
            All content, design, and code on this website are the property of Real Online Compass and are protected by copyright laws.
          </p>
        </div>

        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Changes</h2>
          <p class="text-sm leading-relaxed">
            We reserve the right to modify these terms at any time. Continued use of the service constitutes acceptance of the new terms.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
