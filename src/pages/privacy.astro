---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy" description="Privacy policy for Real Online Compass.">
  <section class="bg-canvas-soft">
    <div class="mx-auto max-w-3xl px-6 py-24">
      <h1 class="text-2xl font-semibold tracking-tight text-ink md:text-[32px] md:leading-[40px] md:tracking-[-1.28px]">
        Privacy Policy
      </h1>
      <p class="mt-4 text-sm text-mute">Last updated: June 2026</p>

      <div class="mt-8 flex flex-col gap-8 text-body">
        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Data Collection</h2>
          <p class="text-sm leading-relaxed">
            Real Online Compass does not collect, store, or transmit any personal data. All sensor readings are processed locally on your device and are never sent to our servers.
          </p>
        </div>

        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Sensor Data</h2>
          <p class="text-sm leading-relaxed">
            Your device's sensors (magnetometer, accelerometer, gyroscope, GPS, ambient light) are accessed only while you actively use the tools. This data is used solely to provide real-time measurements and is discarded when you close the page.
          </p>
        </div>

        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Cookies</h2>
          <p class="text-sm leading-relaxed">
            We do not use cookies or any tracking technologies.
          </p>
        </div>

        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Third-Party Services</h2>
          <p class="text-sm leading-relaxed">
            We do not integrate with any third-party analytics, advertising, or tracking services.
          </p>
        </div>

        <div>
          <h2 class="mb-3 text-base font-semibold text-ink">Contact</h2>
          <p class="text-sm leading-relaxed">
            If you have questions about this privacy policy, please contact us at privacy@realonlinecompass.com.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
