---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Real Online Compass.">
  <section class="bg-canvas-soft">
    <div class="mx-auto max-w-3xl px-6 py-24">
      <h1 class="text-2xl font-semibold tracking-tight text-ink md:text-[32px] md:leading-[40px] md:tracking-[-1.28px]">
        Contact
      </h1>
      <p class="mt-4 text-sm text-body">Have feedback or need support? We'd love to hear from you.</p>

      <div class="mt-12 flex flex-col gap-6">
        <div class="rounded-xl bg-canvas p-6 shadow-card">
          <h3 class="mb-2 text-base font-semibold text-ink">General Inquiries</h3>
          <p class="text-sm text-body">hello@realonlinecompass.com</p>
        </div>

        <div class="rounded-xl bg-canvas p-6 shadow-card">
          <h3 class="mb-2 text-base font-semibold text-ink">Bug Reports</h3>
          <p class="text-sm text-body">Found an issue? Let us know at bugs@realonlinecompass.com</p>
        </div>

        <div class="rounded-xl bg-canvas p-6 shadow-card">
          <h3 class="mb-2 text-base font-semibold text-ink">Feature Requests</h3>
          <p class="text-sm text-body">Suggest new tools or improvements at feedback@realonlinecompass.com</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
